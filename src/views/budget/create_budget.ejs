<% layout("/layouts/dashboard_layout") -%>

<div class="transaction-container">
  <h2 class="title">Add Budget</h2>

  <form action="/budget/create" method="POST" class="transaction-form" id="budgetForm">
    
    <!-- Budget Name -->
    <div class="form-group">
      <label>Budget Name</label>
      <textarea
        name="budgetName"
        rows="2"
        placeholder="Add Budget Name..."
        required
      ></textarea>
    </div>

    <!-- Amount -->
    <div class="form-group">
      <label>Budget Amount</label>
      <input type="number" name="amount" placeholder="Enter amount" required />
    </div>

    <!-- Category -->
    <div class="form-group">
      <label>Category</label>
      <select name="categoryId" required>
        <option value="">Select Budget Category</option>
        <% categories.forEach(category => { %>
          <option value="<%= category.id %>">
            <%= category.categoryName %> 
            (<%= category.transaction_type.name %>)
          </option>
        <% }) %>
      </select>
    </div>

    <!-- Tabs -->
    <div class="filter-container">
      <button type="button" class="filter-tab active" data-type="monthly">Monthly</button>
      <button type="button" class="filter-tab" data-type="yearly">Yearly</button>
      <button type="button" class="filter-tab custom" id="customBtn" data-type="range">
        📅 Select Range
      </button>
    </div>

    <!-- Hidden Inputs -->
    <input type="hidden" name="budgetType" id="budgetType" value="monthly" />
    <input type="hidden" name="startDate" id="startDate" />
    <input type="hidden" name="endDate" id="endDate" />

    <!-- Required for Flatpickr -->
    <input type="text" id="rangePicker" style="display:none;" />

    <!-- Submit -->
    <button type="submit" class="submit-btn">+ Add Budget</button>
  </form>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {

  const tabs = document.querySelectorAll(".filter-tab");
  const customBtn = document.getElementById("customBtn");
  const rangeInput = document.getElementById("rangePicker");
  const budgetTypeInput = document.getElementById("budgetType");
  const startDateInput = document.getElementById("startDate");
  const endDateInput = document.getElementById("endDate");

  // Format date (UI only)
  function formatDate(date) {
    return date.toLocaleDateString("en-GB", {
      day: "2-digit",
      month: "short",
    });
  }

  // Tab handling
  tabs.forEach((tab) => {
    tab.addEventListener("click", function () {
      tabs.forEach((t) => t.classList.remove("active"));
      this.classList.add("active");

      const type = this.getAttribute("data-type");
      budgetTypeInput.value = type;

      // Reset dates when switching
      if (type !== "range") {
        startDateInput.value = "";
        endDateInput.value = "";
        customBtn.innerHTML = "📅 Select Range";
      }

      // Open picker only for range
      if (type === "range") {
        picker.open();
      }
    });
  });

  // Flatpickr init
  const picker = flatpickr(rangeInput, {
    mode: "range",
    dateFormat: "Y-m-d",

    onClose: function (dates) {
      if (dates.length === 2) {
        const start = dates[0];
        const end = dates[1];

        // UI text
        customBtn.innerHTML = `📅 ${formatDate(start)} - ${formatDate(end)}`;

        // Backend format (YYYY-MM-DD)
        startDateInput.value = start.toISOString().split("T")[0];
        endDateInput.value = end.toISOString().split("T")[0];

        // Set type
        budgetTypeInput.value = "range";

        // Activate tab
        tabs.forEach((t) => t.classList.remove("active"));
        customBtn.classList.add("active");
      }
    },
  });

  // Submit validation
  document.getElementById("budgetForm").addEventListener("submit", function (e) {
    const type = budgetTypeInput.value;

    if (type === "range") {
      if (!startDateInput.value || !endDateInput.value) {
        e.preventDefault();
        alert("Please select a valid date range");
      }
    }
  });

});
</script>