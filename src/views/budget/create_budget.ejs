<% layout("/layouts/dashboard_layout") -%>

<div class="transaction-container" style=" margin-left: 240px; ">
  <h2 class="title">
    <%= budget ? "Edit Budget" : "Add Budget" %>
  </h2>

  <form 
    action="<%= budget ? `/budget/edit/${budget.id}?_method=put` : '/budget/create' %>" 
    method="POST" 
    class="transaction-form" 
    id="budgetForm"
  >
     
    <!-- Budget Name -->
    <div class="form-group">
      <label>Budget Name</label>
      <textarea
        name="budgetName"
        rows="2"
        placeholder="Add Budget Name..."
        required
      ><%= budget?.budgetName || "" %></textarea>
    </div>

    <!-- Amount -->
    <div class="form-group">
      <label>Budget Amount</label>
      <input 
        type="number" 
        name="amount" 
        placeholder="Enter amount" 
        value="<%= budget?.amount || '' %>"
        required 
      />
    </div>

    <!-- Category -->
    <div class="form-group">
      <label>Category</label>
      <select name="categoryId" required>
        <option value="">Select Budget Category</option>
        <% categories.forEach(category => { %>
          <option 
            value="<%= category.id %>"
            <%= budget && budget.categoryId === category.id ? "selected" : "" %>
          >
            <%= category.categoryName %> 
            (<%= category.transaction_type.name %>)
          </option>
        <% }) %>
      </select>
    </div>

    <!-- Tabs -->
    <div class="filter-container">
      <button 
        type="button"
        class="filter-tab <%= !budget || budget.budgetType === 'monthly' ? 'active' : '' %>"
        data-type="monthly">
        Monthly
      </button>

      <button 
        type="button"
        class="filter-tab <%= budget?.budgetType === 'yearly' ? 'active' : '' %>"
        data-type="yearly">
        Yearly
      </button>

      <button 
        type="button"
        class="filter-tab custom <%= budget?.budgetType === 'range' ? 'active' : '' %>"
        id="customBtn"
        data-type="range">
        
        <% if (budget?.budgetType === "range" && budget.startDate && budget.endDate) { %>
          📅 
          <%= new Date(budget.startDate).toLocaleDateString("en-GB",{day:"2-digit",month:"short"}) %>
          -
          <%= new Date(budget.endDate).toLocaleDateString("en-GB",{day:"2-digit",month:"short"}) %>
        <% } else { %>
          📅 Select Range
        <% } %>
      </button>
    </div>

    <input type="hidden" name="budgetType" id="budgetType" value="<%= budget?.budgetType || 'monthly' %>" />
    <input type="hidden" name="startDate" id="startDate" value="<%= budget?.startDate || '' %>" />
    <input type="hidden" name="endDate" id="endDate" value="<%= budget?.endDate || '' %>" />

    <input type="text" id="rangePicker" style="display:none;" />

    <button type="submit" class="submit-btn">
      <%= budget ? "✏️ Update Budget" : "+ Add Budget" %>
    </button>
  </form>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {

  const tabs = document.querySelectorAll(".filter-tab");
  const customBtn = document.getElementById("customBtn");
  const rangeInput = document.getElementById("rangePicker");
  const budgetTypeInput = document.getElementById("budgetType");
  const startDateInput = document.getElementById("startDate");
  const endDateInput = document.getElementById("endDate");

  function formatDate(date) {
    return date.toLocaleDateString("en-GB", {
      day: "2-digit",
      month: "short",
    });
  }

  const picker = flatpickr(rangeInput, {
    mode: "range",
    dateFormat: "Y-m-d",

    onClose: function (dates) {
      if (dates.length === 2) {
        const start = dates[0];
        const end = dates[1];

        customBtn.innerHTML = `📅 ${formatDate(start)} - ${formatDate(end)}`;

        startDateInput.value = start.toISOString().split("T")[0];
        endDateInput.value = end.toISOString().split("T")[0];

        budgetTypeInput.value = "range";

        tabs.forEach((t) => t.classList.remove("active"));
        customBtn.classList.add("active");
      }
    },
  });

  // Prefill edit mode
  const existingStart = startDateInput.value;
  const existingEnd = endDateInput.value;

  if (existingStart && existingEnd) {
    picker.setDate([existingStart, existingEnd]);

    const start = new Date(existingStart);
    const end = new Date(existingEnd);

    customBtn.innerHTML = `📅 ${formatDate(start)} - ${formatDate(end)}`;
  }


  tabs.forEach((tab) => {
    tab.addEventListener("click", function () {
      tabs.forEach((t) => t.classList.remove("active"));
      this.classList.add("active");

      const type = this.getAttribute("data-type");
      budgetTypeInput.value = type;

      if (type !== "range") {
        startDateInput.value = "";
        endDateInput.value = "";
        customBtn.innerHTML = "📅 Select Range";
      }

      if (type === "range") {
        picker.open();

       
        if (startDateInput.value && endDateInput.value) {
          picker.setDate([startDateInput.value, endDateInput.value]);
        }
      }
    });
  });

  
  document.getElementById("budgetForm").addEventListener("submit", function (e) {
    const type = budgetTypeInput.value;

    if (type === "range") {
      if (!startDateInput.value || !endDateInput.value) {
        e.preventDefault();
        alert("Please select a valid date range");
      }
    }
  });

});
</script>