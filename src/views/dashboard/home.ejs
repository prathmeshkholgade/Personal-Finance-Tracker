<% layout("/layouts/dashboard_layout") -%>

<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="dash-root">

  <!-- ✦ Header -->
  <div class="dash-header">
    <div>
      <p class="dash-greeting">Good day 👋</p>
      <h1 class="dash-title">Financial Overview</h1>
    </div>
    <div class="dash-date" id="liveDate"></div>
  </div>

  <!-- ✦ Summary Cards -->
  <div class="dash-cards">
    <div class="card income">
      <div class="card-icon">↑</div>
      <div class="card-body">
        <span class="card-label">Total Income</span>
        <span class="card-value">₹<%= totalIncome.toLocaleString('en-IN') %></span>
      </div>
    </div>

    <div class="card expense">
      <div class="card-icon">↓</div>
      <div class="card-body">
        <span class="card-label">Total Expense</span>
        <span class="card-value">₹<%= totalExpense.toLocaleString('en-IN') %></span>
      </div>
    </div>

    <div class="card balance">
      <div class="card-icon">◈</div>
      <div class="card-body">
        <span class="card-label">Net Balance</span>
        <span class="card-value <%= balance >= 0 ? 'positive' : 'negative' %>">
          <%= balance >= 0 ? '+' : '' %>₹<%= Math.abs(balance).toLocaleString('en-IN') %>
        </span>
      </div>
    </div>
  </div>

  <!-- ✦ Charts -->
  <div class="chart-row">

    <div class="chart-card pie-card">
      <div class="chart-header">
        <h3>Income vs Expense</h3>
        <span class="chart-tag">Breakdown</span>
      </div>

      <div class="pie-wrapper">
        <canvas id="pieChart"></canvas>
        <div class="pie-center-label">
          <span class="pie-ratio"><%= totalIncome > 0 ? Math.round((totalExpense / totalIncome) * 100) : 0 %>%</span>
          <span class="pie-sub">spent</span>
        </div>
      </div>

      <div class="pie-legend">
        <div class="legend-item"><span class="dot income-dot"></span>Income ₹<%= totalIncome.toLocaleString('en-IN') %></div>
        <div class="legend-item"><span class="dot expense-dot"></span>Expense ₹<%= totalExpense.toLocaleString('en-IN') %></div>
      </div>
    </div>

    <div class="chart-card bar-card">
      <div class="chart-header">
        <h3>Budget vs Spent</h3>
        <div class="bar-legend">
          <span class="bar-leg-item"><span class="bar-leg-dot" style="background:#6366f1"></span>Budget</span>
          <span class="bar-leg-item"><span class="bar-leg-dot" style="background:#f43f5e"></span>Spent</span>
        </div>
      </div>

      <% if (budgetProgress.length === 0) { %>
        <div class="empty-chart">No budget data yet</div>
      <% } else { %>
        <canvas id="barChart"></canvas>
      <% } %>
    </div>

  </div>

  <!-- ✦ Budget -->
  <div class="budget-section">

    <div class="section-header">
      <h2>Budget Tracker</h2>
      <span class="budget-count"><%= budgetProgress.length %> active</span>
    </div>

    <% if (budgetProgress.length === 0) { %>
      <div class="empty-state">
        <span class="empty-icon">📊</span>
        <p>No budgets set yet</p>
      </div>
    <% } %>

    <div class="budget-grid">
      <% budgetProgress.forEach((b, i) => {
        const pct = Math.min(Math.round(b.percentage), 100);
        const danger = pct >= 90;
        const warn = pct >= 70 && pct < 90;
      %>

      <div class="budget-card">

        <div class="budget-top">
          <div class="budget-cat">
            <div class="cat-dot" style="background:<%= b.color %>"></div>
            <div>
              <h4><%= b.category %></h4>
              <small class="budget-type-pill <%= b.budgetType %>"><%= b.budgetType %></small>
            </div>
          </div>

          <div class="budget-amounts">
            ₹<%= b.spent.toLocaleString('en-IN') %> / ₹<%= b.budgetAmount.toLocaleString('en-IN') %>
          </div>
        </div>

        <div class="progress-track">
          <div class="progress-fill"
            style="width:<%= pct %>%; background:<%= danger ? '#ef4444' : warn ? '#f59e0b' : b.color %>;">
          </div>
        </div>

        <div class="budget-foot">
          <span class="<%= danger ? 'over' : '' %>">
            <%= b.remaining >= 0
              ? '₹' + b.remaining.toLocaleString('en-IN') + ' remaining'
              : '₹' + Math.abs(b.remaining).toLocaleString('en-IN') + ' over' %>
          </span>
          <span class="pct-badge <%= danger ? 'danger' : warn ? 'warn' : 'ok' %>"><%= pct %>%</span>
        </div>

      </div>

      <% }) %>
    </div>

  </div>

</div>

<script>
document.getElementById('liveDate').textContent =
  new Date().toLocaleDateString('en-IN', {
    weekday:'long', day:'numeric', month:'long', year:'numeric'
  });

new Chart(document.getElementById('pieChart'), {
  type: 'doughnut',
  data: {
    labels: ['Income', 'Expense'],
    datasets: [{
      data: [<%= totalIncome %>, <%= totalExpense %>],
      backgroundColor: ['#22c55e','#f43f5e']
    }]
  },
  options: { cutout: '70%', plugins: { legend: { display: false } } }
});

<% if (budgetProgress.length > 0) { %>
new Chart(document.getElementById('barChart'), {
  type: 'bar',
  data: {
    labels: <%- JSON.stringify(budgetProgress.map(b => b.category)) %>,
    datasets: [
      { label: 'Budget', data: <%- JSON.stringify(budgetProgress.map(b => b.budgetAmount)) %> },
      { label: 'Spent', data: <%- JSON.stringify(budgetProgress.map(b => b.spent)) %> }
    ]
  },
  options: { plugins: { legend: { display: false } } }
});
<% } %>
</script>

<style>

  .pie-wrapper {
  position: relative;
  width: 120px;   /* ↓ reduced from 150px */
  height: 120px;  /* ↓ reduced from 150px */
  margin: 0 auto 12px;s
}

.pie-wrapper canvas {
  width: 100% !important;
  height: 100% !important;
}
*{box-sizing:border-box;margin:0;padding:0}
body{overflow-x:hidden}

.dash-root{
  font-family:'DM Sans',sans-serif;
  background:#f1f5f9;
  padding:30px;
}

/* header */
.dash-header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:20px;
}

/* cards */
.dash-cards{
  display:flex;
  gap:16px;
  flex-wrap:wrap;
}

.card{
  flex:1;
  min-width:220px;
  display:flex;
  gap:10px;
  padding:18px;
  background:#fff;
  border-radius:14px;
}

/* charts */
.chart-row{
  display:flex;
  gap:20px;
  margin-top:20px;
  flex-wrap:wrap;
}

.chart-card{
  background:#fff;
  padding:20px;
  border-radius:14px;
  flex:1;
  min-width:280px;
}

/* budget */
.budget-grid{
  display:flex;
  flex-wrap:wrap;
  gap:14px;
}

.budget-card{
  background:#fff;
  padding:15px;
  border-radius:12px;
  flex:1 1 280px;
}

.progress-track{
  height:6px;
  background:#eee;
  border-radius:10px;
  margin:10px 0;
}

.progress-fill{
  height:100%;
  border-radius:10px;
}

.budget-top{
  display:flex;
  justify-content:space-between;
}

.budget-foot{
  display:flex;
  justify-content:space-between;
}

/* responsive */
@media(max-width:768px){
  .dash-header{flex-direction:column;align-items:flex-start}
}
</style>