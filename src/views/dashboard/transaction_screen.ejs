<% layout("/layouts/dashboard_layout") -%>

  <div class="transaction-list-container">

    <!-- Header Section -->
    <div class="transaction-list-header">
      <div>
        <h1 class="page-title">💰 Transaction History</h1>
        <p class="page-subtitle">Track your income and expenses seamlessly</p>
      </div>
      <form action="/transaction/create" class="inline-form">
        <button class="add-transaction-btn">
          <svg stroke="currentColor" fill="none" stroke-width="2.5" viewBox="0 0 24 24" stroke-linecap="round"
            stroke-linejoin="round" height="18" width="18" xmlns="http://www.w3.org/2000/svg">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
          Add Transaction
        </button>
      </form>
    </div>

    <% if (typeof success !=='undefined' && success.length> 0) { %>
      <div class="success-banner">
        <svg stroke="currentColor" fill="none" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round"
          stroke-linejoin="round" height="20" width="20" xmlns="http://www.w3.org/2000/svg">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
          <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
        <%= success %>
      </div>
      <% } %>

        <!-- Filters -->
        <div class="transaction-filters">
          <button class="filter-btn active" onclick="filterType('all')">All</button>
          <button class="filter-btn t-income" onclick="filterType('Income')">Income</button>
          <button class="filter-btn t-expense" onclick="filterType('Expense')">Expense</button>
        </div>

        <!-- Content Section -->
        <% if (!transactions || transactions.length===0) { %>
          <div class="empty-state">
            <img src="https://cdn-icons-png.flaticon.com/512/7486/7486745.png" alt="No Transactions"
              class="empty-img" />
            <h3>No transactions yet</h3>
            <p>Keep track of your finances by adding your first transaction.</p>
            <form action="/transaction/create" class="inline-form mt-3">
              <button class="add-transaction-btn">Add One Now</button>
            </form>
          </div>
          <% } else { %>
            <div class="transaction-grid">
              <% transactions.forEach(txn=> { %>
                <% const isIncome=txn.category.transaction_type.name==='Income' ; %>

                  <div class="txn-card" data-type="<%= txn.category.transaction_type.name %>">

                    <div class="txn-card-header">
                      <div class="txn-category-badge"
                        style="background:<%= txn.category.color %>20; color: <%= txn.category.color %>;">
                        <span class="txn-dot" style="background:<%= txn.category.color %>;"></span>
                        <%= txn.category.categoryName %>
                      </div>
                      <div class="txn-type <%= isIncome ? 'txn-income' : 'txn-expense' %>">
                        <%= txn.category.transaction_type.name %>
                      </div>
                    </div>

                    <div class="txn-card-body">
                      <h3 class="txn-amount <%= isIncome ? 'text-green' : 'text-red' %>">
                        <%= isIncome ? '+' : '-' %> ₹<%= txn.amount %>
                      </h3>
                      <p class="txn-note">
                        <svg stroke="currentColor" fill="none" stroke-width="2" viewBox="0 0 24 24"
                          stroke-linecap="round" stroke-linejoin="round" height="14" width="14"
                          xmlns="http://www.w3.org/2000/svg">
                          <path d="M14 2H6a2 2 0 0 0-2 2v16c0 1.1.9 2 2 2h12a2 2 0 0 0 2-2V8l-6-6z"></path>
                          <path d="M14 3v5h5"></path>
                          <path d="M16 13H8"></path>
                          <path d="M16 17H8"></path>
                          <path d="M10 9H8"></path>
                        </svg>
                        <%= txn.note || "No note added" %>
                      </p>
                      <div class="txn-date">
                        <svg stroke="currentColor" fill="none" stroke-width="2" viewBox="0 0 24 24"
                          stroke-linecap="round" stroke-linejoin="round" height="14" width="14"
                          xmlns="http://www.w3.org/2000/svg">
                          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                          <line x1="16" y1="2" x2="16" y2="6"></line>
                          <line x1="8" y1="2" x2="8" y2="6"></line>
                          <line x1="3" y1="10" x2="21" y2="10"></line>
                        </svg>
                        <%= new Date(txn.date).toLocaleDateString("en-US", { month: "short" , day: "numeric" ,
                          year: "numeric" }) %>
                      </div>
                    </div>

                    <div class="txn-card-footer">
                      <a href="/transaction/edit/<%= txn.id %>" class="txn-btn-edit">Edit</a>
                      <form action="/transaction/delete/<%= txn.id %>?_method=DELETE" method="POST" class="inline-form">
                        <button type="submit" class="txn-btn-delete"
                          onclick="return confirm('Delete this transaction?');">Delete</button>
                      </form>
                    </div>

                  </div>

                  <% }) %>
            </div>

            <% if (totalPage> 1) { %>
              <div class="pagination-container">
                <% if (currentPage> 1) { %>
                  <a href="?page=<%= currentPage - 1 %>" class="page-btn">&laquo; Prev</a>
                  <% } else { %>
                    <span class="page-btn disabled">&laquo; Prev</span>
                    <% } %>

                      <% for(let i=1; i <=totalPage; i++) { %>
                        <a href="?page=<%= i %>" class="page-btn <%= i === currentPage ? 'active' : '' %>">
                          <%= i %>
                        </a>
                        <% } %>

                          <% if (currentPage < totalPage) { %>
                            <a href="?page=<%= currentPage + 1 %>" class="page-btn">Next &raquo;</a>
                            <% } else { %>
                              <span class="page-btn disabled">Next &raquo;</span>
                              <% } %>
              </div>
              <% } %>

                <% } %>

  </div>