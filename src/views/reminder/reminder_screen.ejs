<% layout("/layouts/dashboard_layout") -%>

    <div class="reminder-list-container">
        <!-- Header Section -->
        <div class="reminder-list-header">
            <div>
                <h1 class="page-title">Payment Reminders</h1>
                <p class="page-subtitle">Manage your upcoming and recurring bills smoothly</p>
            </div>
            <a href="/reminder/create" class="add-reminder-btn">
                <svg stroke="currentColor" fill="none" stroke-width="2.5" viewBox="0 0 24 24" stroke-linecap="round"
                    stroke-linejoin="round" height="18" width="18" xmlns="http://www.w3.org/2000/svg">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
                Create Reminder
            </a>
        </div>

        <% if (typeof success !=='undefined' && success.length> 0) { %>
            <div class="success-banner">
                <svg stroke="currentColor" fill="none" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round"
                    stroke-linejoin="round" height="20" width="20" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
                <%= success %>
            </div>
            <% } %>

                <!-- Content Section -->
                <% if (!reminders || reminders.length===0) { %>
                    <div class="empty-state">
                        <img src="https://cdn-icons-png.flaticon.com/512/7486/7486745.png" alt="No Reminders"
                            class="empty-img" />
                        <h3>No reminders yet</h3>
                        <p>Stay on top of your bills by creating your first payment reminder.</p>
                        <a href="/reminder/create" class="add-reminder-btn mt-3">Create One Now</a>
                    </div>
                    <% } else { %>
                        <div class="reminder-grid">
                            <% reminders.forEach(reminder=> { %>
                                <div class="rm-card">
                                    <div class="rm-card-header">
                                        <span class="rm-category">
                                            <%= reminder.category ? reminder.category.categoryName : 'Uncategorized' %>
                                        </span>
                                        <span class="rm-frequency <%= reminder.frequency %>">
                                            <%= reminder.frequency.charAt(0).toUpperCase() + reminder.frequency.slice(1)
                                                %>
                                        </span>
                                    </div>

                                    <div class="rm-card-body">
                                        <h3 class="rm-title">
                                            <%= reminder.title %>
                                        </h3>

                                        <div class="rm-date-row">
                                            <div class="icon-wrapper">
                                                <svg stroke="currentColor" fill="none" stroke-width="2"
                                                    viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"
                                                    height="20" width="20" xmlns="http://www.w3.org/2000/svg">
                                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                                    <line x1="16" y1="2" x2="16" y2="6"></line>
                                                    <line x1="8" y1="2" x2="8" y2="6"></line>
                                                    <line x1="3" y1="10" x2="21" y2="10"></line>
                                                </svg>
                                            </div>
                                            <div class="rm-date-info">
                                                <span class="rm-label">Due Date</span>
                                                <span class="rm-value">
                                                    <%= new Date(reminder.dueDate).toLocaleDateString("en-US", {
                                                        month: "short" , day: "numeric" , year: "numeric" }) %>
                                                </span>
                                            </div>
                                        </div>

                                        <div class="rm-alert-row">
                                            <svg stroke="currentColor" fill="none" stroke-width="2" viewBox="0 0 24 24"
                                                stroke-linecap="round" stroke-linejoin="round" height="18" width="18"
                                                xmlns="http://www.w3.org/2000/svg">
                                                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                                                <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                                            </svg>
                                            <span>Remind <%= reminder.remindBeforeDays %> days before</span>
                                        </div>
                                    </div>

                                    <div class="rm-card-footer">
                                        <a href="/reminder/edit/<%= reminder.id %>" class="rm-btn-edit">Edit</a>
                                        <!-- Using a standard form if you setup delete endpoint with _method override -->
                                        <form action="/reminder/delete/<%= reminder.id %>?_method=DELETE" method="POST"
                                            class="delete-form-inline">
                                            <button type="submit" class="rm-btn-delete"
                                                onclick="return confirm('Are you sure you want to delete this reminder?');">Delete</button>
                                        </form>
                                    </div>
                                </div>
                                <% }) %>
                        </div>
                        <% } %>
    </div>