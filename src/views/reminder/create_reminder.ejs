<% layout("/layouts/dashboard_layout") -%>

  <div class="reminder-container">
    <form
      action="<%= typeof reminder !== 'undefined' && reminder ? '/reminder/edit/' + reminder.id + '?_method=PUT' : '/reminder/create' %>"
      method="POST" class="reminder-form">
      <div class="form-card">
        <h2 class="form-title">
          <%= typeof reminder !=='undefined' && reminder ? "Edit Reminder" : "Create Payment Reminder" %>
        </h2>

        <div class="form-group">
          <label>Title</label>
          <input type="text" name="title" placeholder="e.g. Electric Bill"
            value="<%= typeof reminder !== 'undefined' && reminder ? reminder.title : '' %>" required />
        </div>

        <div class="form-group">
          <label>Category</label>
          <select name="categoryId" required>
            <% if(typeof categories !=='undefined' ) { %>
              <% for (let cat of categories) { %>
                <option value=<%=cat.id%>>
                  <%=cat.categoryName %>
                </option>
                <% } %>
                  <% } %>

          </select>
        </div>

        <div class="form-group">
          <label>Due Date</label>
          <input type="date" name="dueDate"
            value="<%= typeof reminder !== 'undefined' && reminder && reminder.dueDate ? new Date(reminder.dueDate).toISOString().split('T')[0] : '' %>"
            required />
        </div>

        <div class="form-group">
          <label>Frequency</label>
          <select name="frequency" required>
            <option value="once" <%=typeof reminder !=='undefined' && reminder && reminder.frequency==='once'
              ? 'selected' : '' %>>Once</option>
            <option value="monthly" <%=typeof reminder !=='undefined' && reminder && reminder.frequency==='monthly'
              ? 'selected' : '' %>>Monthly</option>
            <option value="quarterly" <%=typeof reminder !=='undefined' && reminder && reminder.frequency==='quarterly'
              ? 'selected' : '' %>>Quarterly</option>
            <option value="yearly" <%=typeof reminder !=='undefined' && reminder && reminder.frequency==='yearly'
              ? 'selected' : '' %>>Yearly</option>
          </select>
        </div>

        <div class="form-group">
          <label>Remind Before (Days)</label>
          <input type="number" name="remindBeforeDays" min="1"
            value="<%= typeof reminder !== 'undefined' && reminder ? reminder.remindBeforeDays : 1 %>" required />
        </div>

        <button type="submit" class="submit-btn">
          <%= typeof reminder !=='undefined' && reminder ? "Update Reminder" : "+ Add Reminder" %>
        </button>
      </div>
    </form>
  </div>